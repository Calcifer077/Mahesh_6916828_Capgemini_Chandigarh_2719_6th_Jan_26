@page
@model EventBooking.Web.Pages.EventsModel
@{
    ViewData["Title"] = "Browse Events";
}

<style>
    /* Custom Theme */
    .bg-gradient-primary {
        background: linear-gradient(135deg, #6f42c1, #4f46e5);
    }

    .btn-gradient {
        background: linear-gradient(135deg, #6f42c1, #4f46e5);
        color: white;
        border: none;
    }

    .btn-gradient:hover {
        background: linear-gradient(135deg, #5a32a3, #4338ca);
        color: white;
    }

    .card {
        border-radius: 12px;
    }

    .modal-content {
        border-radius: 12px;
    }

    body {
        background-color: #f8f9fc;
    }
</style>

<div class="container py-4">

    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="fw-bold mb-0 text-dark">
            <i class="bi bi-calendar3 me-2 text-primary"></i> Available Events
        </h2>
    </div>

    <!-- Booking Modal -->
    <div class="modal fade" id="bookingModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow border-0">

                <div class="modal-header bg-gradient-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-ticket-perforated me-2"></i> Book Tickets
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body px-4 py-3">
                    <div id="bookingAlert" class="alert d-none"></div>

                    <h5 id="modalEventTitle" class="fw-semibold text-dark"></h5>

                    <p class="text-muted mb-3">
                        Available Seats:
                        <span id="modalAvailableSeats" class="badge bg-success fs-6"></span>
                    </p>

                    <input type="hidden" id="modalEventId" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Number of Seats</label>
                        <input type="number" id="seatsInput"
                               class="form-control form-control-lg"
                               min="1" placeholder="Enter number of seats" />
                        <div class="invalid-feedback" id="seatsError"></div>
                    </div>
                </div>

                <div class="modal-footer px-4 pb-4 border-0">
                    <button class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button class="btn btn-gradient px-4" onclick="confirmBooking()">
                        <i class="bi bi-check-circle me-1"></i> Confirm Booking
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- Events Section -->
    <div class="card shadow-sm border-0 bg-white">
        <div class="card-body">

            <div class="row g-4" id="eventsContainer">
                <!-- Loading State -->
                <div class="col-12 text-center py-5">
                    <div class="spinner-border text-primary mb-3" role="status"></div>
                    <p class="text-muted mb-0">Loading events, please wait...</p>
                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
<script>
    loadEvents();
</script>
}