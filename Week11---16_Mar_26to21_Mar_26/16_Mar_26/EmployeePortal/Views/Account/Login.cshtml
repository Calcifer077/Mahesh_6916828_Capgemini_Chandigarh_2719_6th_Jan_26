<h2>Admin Login</h2>

@if (ViewBag.Error != null)
{
    <p style="color:red">@ViewBag.Error</p>
}

<form method="post">

    <label>Username</label>
    <input name="username" />

    <label>Password</label>
    <input type="password" name="password" />

    <br />

    <button type="submit">Login</button>

</form>