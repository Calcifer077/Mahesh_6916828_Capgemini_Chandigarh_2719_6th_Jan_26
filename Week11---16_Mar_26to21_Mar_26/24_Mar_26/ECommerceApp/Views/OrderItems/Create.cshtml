@model ECommerceApp.Models.OrderItem

@{
    ViewData["Title"] = "Create Order Item";
}

<div class="container mt-4">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-sm">

                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"> Add Order Item</h4>
                </div>

                <div class="card-body">

                    <form asp-action="Create">

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <!-- Order -->
                        <div class="mb-3">
                            <label asp-for="OrderId" class="form-label fw-semibold"></label>
                            <select asp-for="OrderId" class="form-select" asp-items="ViewBag.OrderId">
                                <option value="">-- Select Order --</option>
                            </select>
                        </div>

                        <!-- Product -->
                        <div class="mb-3">
                            <label asp-for="ProductId" class="form-label fw-semibold"></label>
                            <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductId">
                                <option value="">-- Select Product --</option>
                            </select>
                        </div>

                        <!-- Quantity -->
                        <div class="mb-3">
                            <label asp-for="Quantity" class="form-label fw-semibold"></label>
                            <input asp-for="Quantity" class="form-control" placeholder="Enter quantity" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Back to List
                            </a>

                            <button type="submit" class="btn btn-primary">
                                Create
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}