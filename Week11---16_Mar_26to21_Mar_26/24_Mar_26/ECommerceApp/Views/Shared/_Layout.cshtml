<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ECommerceApp</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ECommerceApp.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    <!-- HEADER / NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    🛒 ECommerceApp
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <!-- Left Menu -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>

                        <!-- Dropdown for Management -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                Manage
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index">Categories</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="Index">Products</a></li>
                                <li><a class="dropdown-item" asp-controller="Customers" asp-action="Index">Customers</a></li>
                                <li><a class="dropdown-item" asp-controller="Orders" asp-action="Index">Orders</a></li>
                                <li><a class="dropdown-item" asp-controller="OrderItems" asp-action="Index">Order Items</a></li>
                                <li><a class="dropdown-item" asp-controller="ShippingDetails" asp-action="Index">Shipping Details</a></li>
                            </ul>
                        </li>
                    </ul>

                    <!-- Right Side -->
                    <div class="d-flex">
                        <a class="btn btn-outline-light me-2" href="/Identity/Account/Login">Login</a>
                        <a class="btn btn-primary" href="/Identity/Account/Register">Register</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- MAIN CONTENT -->
    <main class="flex-grow-1">
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="bg-light border-top mt-auto">
        <div class="container text-center py-3">
            <span class="text-muted">
                &copy; 2026 - ECommerceApp |
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </span>
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>